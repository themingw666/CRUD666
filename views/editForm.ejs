<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Edit Item</title>
</head>
<body>
    <h1>Edit Item</h1>
    <% if (item) { %>
    <form action="/items/edit/<%= item.id %>" method="POST">
        <div>
            <label>Name:</label><br>
            <input type="text" name="name" value="<%= item.name %>" required>
        </div>
        <br>
        <div>
            <label>Description:</label><br>
            <textarea name="description" required><%= item.description %></textarea>
        </div>
        <br>
        <div>
            <label>Price:</label><br>
            <input type="number" name="price" value="<%= item.price %>" required>
        </div>
        <br>
        <div>
            <label>Quantity:</label><br>
            <input type="number" name="quantity" value="<%= item.quantity %>" required>
        </div>
        <br>
        <div>
            <label>Is Active:</label><br>
            <input type="radio" name="is_active" value="true" <%= item.is_active ? 'checked' : '' %> required> Yes
            <input type="radio" name="is_active" value="false" <%= !item.is_active ? 'checked' : '' %> required> No
        </div>
        <br>
        <button type="submit">Update</button>
        <a href="/items">Cancel</a>
    </form>
    <% } else { %>
        <p>Item not found.</p>
        <a href="/items">Go back</a>
    <% } %>
</body>
</html>