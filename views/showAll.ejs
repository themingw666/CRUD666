<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>CRUD Items</title>
</head>
<body>
    <h1>List of Items</h1>
    <a href="/items/add">Add New Item</a> | 
    <a href="/items/generate">Generate 50 Random Items</a> | 
    <a href="/items/clear" onclick="return confirm('Are you sure you want to delete all items?')">Delete All Items</a>
    <br><br>
    <table border="1">
        <thead>
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Description</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Is Active</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% if (items && items.length > 0) { %>
                <% items.forEach(item => { %>
                <tr>
                    <td><%= item.id %></td>
                    <td><%= item.name %></td>
                    <td><%= item.description %></td>
                    <td><%= item.price %></td>
                    <td><%= item.quantity %></td>
                    <td><%= item.is_active ? 'Yes' : 'No' %></td>
                    <td>
                        <a href="/items/edit/<%= item.id %>">Edit</a> | 
                        <a href="/items/delete/<%= item.id %>" onclick="return confirm('Are you sure you want to delete this item?')">Delete</a>
                    </td>
                </tr>
                <% }) %>
            <% } else { %>
                <tr>
                    <td colspan="7">No items found.</td>
                </tr>
            <% } %>
        </tbody>
    </table>
</body>
</html>